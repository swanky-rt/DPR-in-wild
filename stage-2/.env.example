# LLM Configuration for LiteLLM
# See all supported providers: https://docs.litellm.ai/docs/providers

# --- Option 1: OpenAI ---
# OPENAI_API_KEY=sk-...
# LLM_MODEL=openai/gpt-4o

# --- Option 2: Together AI ---
# TOGETHERAI_API_KEY=...
# LLM_MODEL=together_ai/meta-llama/Llama-3.3-70B-Instruct-Turbo

# --- Option 3: Ollama (local) ---
# LLM_MODEL=ollama/llama3.3

# --- Option 4: Self-hosted vLLM ---
# LLM_API_BASE=http://localhost:8000/v1
# LLM_MODEL=openai/meta-llama/Llama-3.3-70B-Instruct

# --- Option 5: Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=anthropic/claude-sonnet-4-5-20250929
