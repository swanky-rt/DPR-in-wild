\outl0\strokewidth0 \strokec2 Hi all, below are the refined steps to connect to the LLM on Unity via localhost.\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls1\ilvl0\cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	1	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 SSH into Unity and go to the project directory:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 cd /project/pi_dagarwal_umass_edu/project_18\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls2\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	2	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Request a GPU node:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 srun --partition=gpu-preempt \\\
  --nodes=1 \\\
  --gres=gpu:a100:1 \\\
  --mem=80G \\\
  --time=02:00:00 \\\
  --pty bash\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls3\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	3	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Activate the virtual environment:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 source /project/pi_dagarwal_umass_edu/project_18/venv/bin/activate\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls4\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	4	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Start the vLLM server:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 python -m vllm.entrypoints.openai.api_server \\\
  --model /datasets/ai/llama3/hub/models--meta-llama--Llama-3.1-8B-Instruct/snapshots/0e9e39f249a16976918f6564b8830bc894c89659 \\\
  --port 8000 \\\
  --host 0.0.0.0 \\\
  --tensor-parallel-size 1\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls5\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	5	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Wait until the server is fully up and listening on port 8000.\
\ls5\ilvl0\kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	6	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Open a new terminal, SSH into Unity again, and go to the project directory:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 cd /project/pi_dagarwal_umass_edu/project_18\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls6\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	7	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Check your running job:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 squeue -u $USER\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls7\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	8	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Attach a shell to the same running GPU job:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 srun --jobid=<JOB_ID> --overlap --pty bash\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls8\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	9	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Activate the same virtual environment again:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 source /project/pi_dagarwal_umass_edu/project_18/venv/bin/activate\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls9\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	10	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Go to the correct stage folder:\
\pard\pardeftab720\partightenfactor0

\f1 \cf0 cd /project/pi_dagarwal_umass_edu/project_18/stage-2\
\pard\tx220\tx720\pardeftab720\li720\fi-720\sa240\partightenfactor0
\ls10\ilvl0
\f0 \cf0 \kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	11	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 Verify the model exposed by the local endpoint:\
